# Copy this to .env.local and fill with your values for local development
# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/carebot?retryWrites=true&w=majority

# JWT / NextAuth secret
NEXTAUTH_SECRET=some-long-random-secret
JWT_SECRET=some-long-random-secret

# If you run the API on a separate host (dev/prod), set this. Otherwise leave blank to use relative /api paths
NEXT_PUBLIC_API_URL=

# Optional: local port or other settings
# PORT=3000
