# Example environment variables (DO NOT commit secrets)
# Copy this to `.env.local` and fill in real values for local development

# Public API base (client-side)
NEXT_PUBLIC_API_URL=/api

# NextAuth / OAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Generative AI (server-side)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-key

# MongoDB
MONGODB_URI=your-mongodb-connection-string
