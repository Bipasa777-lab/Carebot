# Example environment variables (DO NOT commit secrets)
# Copy this to `.env.local` and fill in real values for local development

# Public API base (client-side)
NEXT_PUBLIC_API_URL=/api

# NextAuth / OAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production-minimum-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Generative AI (server-side)
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyA6_-S8CRW5ChvfMFFoayCwpbcTMYny_z0

# MongoDB
MONGODB_URI=your-mongodb-connection-string
